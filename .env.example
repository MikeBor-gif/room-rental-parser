# Скопируйте этот файл в .env и заполните значения для локального запуска.
# В GitHub Actions эти значения задаются через Secrets репозитория.

# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ваш chat_id (узнать через @userinfobot или getUpdates)
TELEGRAM_CHAT_ID=

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Необязательные фильтры объявлений
# Максимальная цена (число); пусто — без ограничения
MAX_PRICE=
# Ключевые слова через запятую (объявление должно содержать хотя бы одно); пусто — без фильтра
KEYWORDS=
