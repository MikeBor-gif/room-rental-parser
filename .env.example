# Скопируйте этот файл в .env и заполните значения для локального запуска.
# В GitHub Actions эти значения задаются через Secrets репозитория.

# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=

# (устарело, для старого одиночного режима) Ваш chat_id
TELEGRAM_CHAT_ID=

# --- Supabase (БД бота) — см. docs/supabase-setup.md ---
# Project URL, вида https://abcdefgh.supabase.co
SUPABASE_URL=
# service_role key (Project Settings -> API). НИКОГДА не коммитить!
SUPABASE_SERVICE_KEY=

# --- Бот и тарифы ---
# chat_id администратора: получает уведомления об оплатах, может /approve, /grant, /stats
ADMIN_CHAT_ID=
# Цена премиум-подписки, BYN за 30 дней
TARIFF_PRICE_BYN=15
# Период батч-рассылки для бесплатного тарифа, минут
FREE_BATCH_MINUTES=30
# Максимум фильтров на премиум-тарифе (у бесплатного всегда 1)
PREMIUM_MAX_FILTERS=5
# Реквизиты для ручной оплаты — текст, который бот покажет по кнопке «Оплатить»
# (например: "Карта БелВЭБ 1234 5678 9012 3456, получатель И.И. Иванов")
PAYMENT_DETAILS=

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Интервал опроса в секундах для режима демона (на своей VM / Oracle Cloud).
# 0 или пусто = один прогон и выход (режим для GitHub Actions).
# >0 = бесконечный цикл: проверять каждые N секунд (например, 120 = каждые 2 минуты).
POLL_INTERVAL_SECONDS=

# Необязательные глобальные фильтры объявлений (устарело: фильтры теперь у юзеров в БД)
MAX_PRICE=
KEYWORDS=
